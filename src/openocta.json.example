{
  "agents": {
    "defaults": {
      "workspace": "~/.openocta/workspace"
    },
    "list": [
      {
        "id": "default",
        "default": true,
        "name": "Default Agent",
        "workspace": "~/.openocta/workspace",
        "model": "anthropic/claude-sonnet-4-5",
        "skills": []
      }
    ]
  },
  "gateway": {
    "port": 18900,
    "bind": "loopback"
  },
  "mcp": {
    "servers": {
      "prometheus": {
        "enabled": true,
        "service": "prometheus",
        "serviceUrl": "http://localhost:9090",
        "toolPrefix": "prom"
      }
    }
  }
}
